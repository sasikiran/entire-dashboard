# ============================================================
# Entire Dashboard Server Environment Variables Template
# Copy this file to .env and modify the values as needed
# ============================================================

# ------------------------------------------------------------
# Database Configuration (MySQL)
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=entire-dashboard
DB_USERNAME=root
DB_PASSWORD=your_password_here

# ------------------------------------------------------------
# JWT Authentication Configuration
# ------------------------------------------------------------
# Secret key for signing JWT tokens, MUST be changed to a strong key in production
JWT_SECRET=ChangeThisSecretKeyInProduction

# ------------------------------------------------------------
# Optional Configurations (below have default values, modify as needed)
# ------------------------------------------------------------

# Server port (default: 8080)
# SERVER_PORT=8080

# Git data storage path (default: ./data)
# APP_GIT_DATA_PATH=./data

# Default Git branch (default: entire/checkpoints/v1)
# APP_GIT_DEFAULT_BRANCH=entire/checkpoints/v1

# Git shallow clone depth (default: 1, means only fetch the latest commit)
# APP_GIT_CLONE_DEPTH=1

# Git operation timeout in seconds (default: 300)
# APP_GIT_TIMEOUT_SECONDS=300

# Git operation retry count (default: 3)
# APP_GIT_RETRY_COUNT=3

# ------------------------------------------------------------
# Checkpoint Sync Configuration
# ------------------------------------------------------------

# Whether to enable scheduled sync (default: true)
# APP_CHECKPOINT_SYNC_ENABLED=true

# Sync job Cron expression (default: every 15 minutes)
# APP_CHECKPOINT_SYNC_CRON=0 */15 * * * ?

# Sync target branch (default: entire/checkpoints/v1)
# APP_CHECKPOINT_SYNC_BRANCH=entire/checkpoints/v1

# Branch clone depth (default: 0, means full history)
# APP_CHECKPOINT_SYNC_CLONE_DEPTH=0

# ============================================================
# Development Environment Recommended Configuration
# ============================================================
# For local development, you can use the following simplified configuration:
#
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=entire-dashboard
# DB_USERNAME=root
# DB_PASSWORD=root
# JWT_SECRET=dev-secret-key-change-in-production
